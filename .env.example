# Copy this file to `.env` and fill in your local settings.

SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=mysql+pymysql://username:password@localhost:3306/book_recomm

# Optional Redis for captcha / email code storage
REDIS_URL=

# JWT and captcha
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRES_IN=7200
CAPTCHA_EXPIRES_IN=300
AUTH_CODE_EXPIRES_IN=600
AUTH_CODE_RESEND_SECONDS=60
AUTH_CODE_MAX_ATTEMPTS=5
AUTH_CODE_REQUIRE_CAPTCHA=1
AUTH_CODE_MAX_PER_IP_PER_HOUR=10
AUTH_CODE_MAX_PER_IP_PER_DAY=30
AUTH_CODE_MAX_PER_EMAIL_PER_HOUR=5
AUTH_CODE_MAX_PER_EMAIL_PER_DAY=10
ADMIN_REGISTER_CODE=your-admin-register-code
DEFAULT_TENANT_ID=1

# SMTP sender for auth emails
AUTH_NOTIFICATION_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Book Recommend
SMTP_USE_SSL=1
SMTP_USE_TLS=0

# Upload limits
MAX_AVATAR_UPLOAD_SIZE=2097152

# Tencent COS
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_DOMAIN=

# Logging
LOG_LEVEL=INFO
LOG_DIR=
LOG_RETENTION_DAYS=14

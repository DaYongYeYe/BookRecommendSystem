# 复制此文件为 .env 并填写实际值
# cp .env.example .env

# 应用密钥（生产环境务必修改）
SECRET_KEY=your-secret-key-here

# 数据库连接（MySQL）
# 格式: mysql+pymysql://用户:密码@主机:端口/数据库名
DATABASE_URL=mysql+pymysql://book_recomm:nrinwdRC4DpGxeWz@localhost:3306/book_recomm

# Redis 连接（可选，不需要可留空）
REDIS_URL=

# JWT 配置
JWT_SECRET_KEY=your-jwt-secret-key
JWT_EXPIRES_IN=7200
CAPTCHA_EXPIRES_IN=300
ADMIN_REGISTER_CODE=your-admin-register-code
DEFAULT_TENANT_ID=1

# 头像上传限制（字节，默认 2MB）
MAX_AVATAR_UPLOAD_SIZE=2097152

# 腾讯云 COS 配置（用于头像上传）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
# 可选：自定义访问域名（如 https://cdn.example.com）。不填时使用默认 COS 域名
COS_DOMAIN=

# 日志配置
# 级别可选：DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO
# 日志目录（为空则默认 instance/logs）
LOG_DIR=
# 日志保留天数（按天轮转）
LOG_RETENTION_DAYS=14
